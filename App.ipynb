    "            vd_sedang = max(0.0, min(vd / 0.5, (1.0 - vd) / 0.5))\n",
    "            vd_tinggi = max(0.0, (vd - 0.5) / 0.5) if vd >= 0.5 else 0.0\n",
    "            \n",
    "            w1 = min(vp_tinggi, vd_rendah)\n",
    "            w2 = min(vn_tinggi, vp_rendah, vd_rendah)\n",
